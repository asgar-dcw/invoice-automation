      "id": "0312b88a-6677-473a-9ce5-f55b082e3b26",
      "name": "Get Harvest Invoices",
      "type": "n8n-nodes-base.harvest",
      "typeVersion": 1,
      "position": [
        672,
        192
      ],
      "executeOnce": true,
      "credentials": {
        "harvestApi": {
          "id": "fZEZm1Mje5qAXs9w",
          "name": "Harvest account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check if triggered by webhook (manual UI) or schedule (automatic)\nconst webhookData = $('Webhook Trigger').all?.()?.[0]?.json;\nconst isWebhookTrigger = webhookData?.clients && Array.isArray(webhookData.clients);\n\nfunction cleanMsg(msg) {\n  if (!msg) return '';\n  return msg\n    .replace(/\\\\n\\\\n/g, '</p><p style=\"margin:0 0 12px;\">')\n    .replace(/\\\\n/g, '<br>')\n    .replace(/\\n\\n/g, '</p><p style=\"margin:0 0 12px;\">')\n    .replace(/\\n/g, '<br>')\n    .trim();\n}\n\n// If webhook trigger — use the selected clients from the UI\nif (isWebhookTrigger) {\n  const emailItems = $('Read Email Templates').all();\n  const seenE = new Set();\n  const emails = emailItems.filter(e => {\n    const n = (e.json.company_name || '').toLowerCase().trim();\n    return seenE.has(n) ? false : seenE.add(n);\n  });\n\n  return webhookData.clients.map(client => {\n    const tmpl = emails.find(e =>\n      (e.json.company_name || '').toLowerCase().trim() === (client.client_name || '').toLowerCase().trim()\n    );\n    return { json: {\n      client_name: client.client_name,\n      harvest_invoice_number: client.harvest_invoice_number || '',\n      total_amount: Number(client.total_amount || 0),\n      payment_method: client.payment_method || 'bank',\n      ar_email: client.ar_email || 'accountsreceivable@dotcomweavers.com',\n      manual_attachment: client.manual_attachment || 'no',\n      email_to: tmpl?.json?.to || '',\n      email_cc: tmpl?.json?.cc || '',\n      email_bcc: tmpl?.json?.bcc || '',\n      email_subject: tmpl?.json?.subject || ('Invoice | ' + client.client_name),\n      email_message: cleanMsg(tmpl?.json?.message || '')\n    }};\n  });\n}\n\n// Otherwise — schedule trigger, read from Google Sheets as normal\nconst harvestInvoices = $('Get Harvest Invoices').all();\nconst configItems = $('Read Config Sheet').all();\nconst emailItems = $('Read Email Templates').all();\n\nconst seenC = new Set();\nconst configs = configItems.filter(c => {\n  const n = (c.json.client_name || '').toLowerCase().trim();\n  return seenC.has(n) ? false : seenC.add(n);\n});\nconst seenE = new Set();\nconst emails = emailItems.filter(e => {\n  const n = (e.json.company_name || '').toLowerCase().trim();\n  return seenE.has(n) ? false : seenE.add(n);\n});\n\nconst latest = new Map();\nfor (const inv of harvestInvoices) {\n  const n = (inv.json.client?.name || '').toLowerCase().trim();\n  const ex = latest.get(n);\n  if (!ex || inv.json.issue_date > ex.json.issue_date) latest.set(n, inv);\n}\n\nconst result = [];\nfor (const [clientName, inv] of latest) {\n  const config = configs.find(c => (c.json.client_name || '').toLowerCase().trim() === clientName);\n  if (!config) continue;\n  const tmpl = emails.find(e => (e.json.company_name || '').toLowerCase().trim() === clientName);\n  result.push({ json: {\n    client_name: inv.json.client?.name || '',\n    harvest_invoice_number: inv.json.number,\n    total_amount: Number(inv.json.amount ?? inv.json.due_amount ?? 0),\n    payment_method: (config.json.payment_method || 'bank').toLowerCase().trim(),\n    ar_email: config.json.ar_email || 'accountsreceivable@dotcomweavers.com',\n    manual_attachment: (config.json.manual_attachment_required || 'no').toLowerCase().trim(),\n    email_to: tmpl?.json?.to || '',\n    email_cc: tmpl?.json?.cc || '',\n    email_bcc: tmpl?.json?.bcc || '',\n    email_subject: tmpl?.json?.subject || ('Invoice | ' + (inv.json.client?.name || '')),\n    email_message: cleanMsg(tmpl?.json?.message || '')\n  }});\n}\nreturn result;"
      },
