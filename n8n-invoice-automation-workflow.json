    {
      "parameters": {
        "sendTo": "accountsreceivable@dotcomweavers.com",
        "subject": "=Invoice Automation Complete — {{ $now.toFormat('MMMM yyyy') }}",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:640px;margin:0 auto;color:#333333;background:#ffffff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;\">\n\n  <!-- Header -->\n  <div style=\"background:#0f172a;padding:32px;text-align:center;\">\n    <img src=\"https://commercemarketplace.adobe.com/media/customer/MAG002771500/65c8c2363e6e2.png\" alt=\"DotcomWeavers\" style=\"height:44px;display:block;margin:0 auto 16px;\"/>\n    <div style=\"width:48px;height:2px;background:#3b82f6;margin:0 auto 16px;\"></div>\n    <h1 style=\"color:#f8fafc;font-size:18px;margin:0;font-weight:600;letter-spacing:0.5px;\">Monthly Invoice Automation Report</h1>\n    <p style=\"color:#94a3b8;font-size:13px;margin:8px 0 0;letter-spacing:0.3px;\">{{ $now.toFormat('MMMM yyyy') }}</p>\n  </div>\n\n  <!-- Green status bar -->\n  <div style=\"background:#dcfce7;padding:14px 28px;border-bottom:1px solid #bbf7d0;display:flex;align-items:center;\">\n    <span style=\"display:inline-block;width:10px;height:10px;background:#16a34a;border-radius:50%;margin-right:10px;\"></span>\n    <p style=\"margin:0;font-size:14px;color:#15803d;font-weight:500;\">All invoice drafts created successfully and are ready for review.</p>\n  </div>\n\n  <!-- Body -->\n  <div style=\"padding:32px;\">\n    <p style=\"font-size:15px;line-height:1.7;margin:0 0 8px;color:#1e293b;\">Hi Team,</p>\n    <p style=\"font-size:14px;line-height:1.8;margin:0 0 28px;color:#475569;\">The monthly invoice automation has completed for <strong style=\"color:#1e293b;\">{{ $now.toFormat('MMMM yyyy') }}</strong>. The following client drafts are saved in the AR inbox and are ready for your review and sending.</p>\n\n    <!-- Client Table -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:32px;border-radius:8px;overflow:hidden;border:1px solid #e2e8f0;\">\n      <thead>\n        <tr style=\"background:#f1f5f9;\">\n          <th style=\"padding:11px 16px;text-align:left;font-size:11px;font-weight:700;color:#64748b;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;\">#</th>\n          <th style=\"padding:11px 16px;text-align:left;font-size:11px;font-weight:700;color:#64748b;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;\">CLIENT NAME</th>\n          <th style=\"padding:11px 16px;text-align:left;font-size:11px;font-weight:700;color:#64748b;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;\">INVOICE NO.</th>\n          <th style=\"padding:11px 16px;text-align:right;font-size:11px;font-weight:700;color:#64748b;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;\">AMOUNT</th>\n          <th style=\"padding:11px 16px;text-align:center;font-size:11px;font-weight:700;color:#64748b;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;\">STATUS</th>\n        </tr>\n      </thead>\n      <tbody>\n        {{ $(&#39;Build Client List&#39;).all().map((item, i) => `&lt;tr style=\"background:${i % 2 === 0 ? &#39;#ffffff&#39; : &#39;#f8fafc&#39;};\"&gt;&lt;td style=\"padding:13px 16px;font-size:13px;color:#94a3b8;border-bottom:1px solid #f1f5f9;\"&gt;${i + 1}&lt;/td&gt;&lt;td style=\"padding:13px 16px;font-size:14px;font-weight:600;color:#1e293b;border-bottom:1px solid #f1f5f9;\"&gt;${item.json.client_name}&lt;/td&gt;&lt;td style=\"padding:13px 16px;font-size:13px;color:#64748b;font-family:monospace;border-bottom:1px solid #f1f5f9;\"&gt;${item.json.harvest_invoice_number}&lt;/td&gt;&lt;td style=\"padding:13px 16px;font-size:14px;font-weight:600;color:#1e293b;text-align:right;border-bottom:1px solid #f1f5f9;\"&gt;$${Number(item.json.total_amount).toLocaleString(&#39;en-US&#39;,{minimumFractionDigits:2,maximumFractionDigits:2})}&lt;/td&gt;&lt;td style=\"padding:13px 16px;text-align:center;border-bottom:1px solid #f1f5f9;\"&gt;${item.json.manual_attachment === &#39;yes&#39; ? &#39;&lt;span style=\"background:#fef3c7;color:#b45309;font-size:11px;padding:3px 8px;border-radius:4px;font-weight:600;white-space:nowrap;\"&gt;ADD ATTACHMENT&lt;/span&gt;&#39; : &#39;&lt;span style=\"background:#dcfce7;color:#16a34a;font-size:11px;padding:3px 8px;border-radius:4px;font-weight:600;\"&gt;Ready&lt;/span&gt;&#39;}&lt;/td&gt;&lt;/tr&gt;`).join(&#39;&#39;) }}\n      </tbody>\n    </table>\n\n    <!-- CTA Button -->\n    <div style=\"text-align:center;margin-bottom:32px;\">\n      <a href=\"https://mail.google.com/mail/u/0/#drafts\" style=\"background:#0f172a;color:#ffffff;padding:14px 40px;text-decoration:none;font-size:14px;font-weight:600;border-radius:6px;display:inline-block;letter-spacing:0.3px;\">Open Gmail Drafts &rarr;</a>\n    </div>\n\n    <!-- Checklist -->\n    <div style=\"background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:20px 24px;margin-bottom:8px;\">\n      <p style=\"margin:0 0 12px;font-size:13px;font-weight:700;color:#92400e;letter-spacing:.03em;\">BEFORE SENDING — CHECKLIST</p>\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\">\n        <tr><td style=\"padding:4px 0;font-size:13px;color:#78350f;line-height:1.6;\"><span style=\"color:#d97706;margin-right:8px;\">&#10003;</span>Review each draft — verify amount, recipient and subject line</td></tr>\n        <tr><td style=\"padding:4px 0;font-size:13px;color:#78350f;line-height:1.6;\"><span style=\"color:#d97706;margin-right:8px;\">&#10003;</span>Click the <strong>View and pay</strong> button to confirm the payment link is working</td></tr>\n        <tr><td style=\"padding:4px 0;font-size:13px;color:#78350f;line-height:1.6;\"><span style=\"color:#d97706;margin-right:8px;\">&#10003;</span>For any draft marked <strong>ADD ATTACHMENT</strong> — attach the timesheet before sending</td></tr>\n        <tr><td style=\"padding:4px 0;font-size:13px;color:#78350f;line-height:1.6;\"><span style=\"color:#d97706;margin-right:8px;\">&#10003;</span>Once reviewed, click <strong>Send</strong> on each draft</td></tr>\n      </table>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"background:#f8fafc;border-top:1px solid #e2e8f0;padding:20px 32px;text-align:center;\">\n    <p style=\"margin:0 0 4px;font-size:12px;color:#94a3b8;\">Sent automatically by the DotcomWeavers Invoice Automation System</p>\n    <p style=\"margin:0;font-size:12px;color:#94a3b8;\">178 East Hanover Ave #103-123, Cedar Knolls, NJ 07960 &nbsp;&bull;&nbsp;\n    <a href=\"mailto:info@dotcomweavers.com\" style=\"color:#64748b;text-decoration:none;\">info@dotcomweavers.com</a> &nbsp;&bull;&nbsp;\n    <a href=\"https://www.dotcomweavers.com\" style=\"color:#64748b;text-decoration:none;\">dotcomweavers.com</a></p>\n  </div>\n\n</div>",
